@model IEnumerable<SistemaGestionAcademica.Models.DTOs.InscripcionDTO>
@{
    ViewData["Title"] = "Inscripcion de Materias";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-pencil-square"></i> @ViewData["Title"]</h2>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5>Mis Materias Inscritas</h5>
    </div>
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Materia</th>
                            <th>Profesor</th>
                            <th>Horario</th>
                            <th>Aula</th>
                            <th>Costo</th>
                            <th>Pago</th>
                            <th>Nota Final</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MateriaNombre</td>
                                <td>@item.ProfesorNombre</td>
                                <td>@item.Horario</td>
                                <td>@item.Aula</td>
                                <td>Bs. @item.Costo.ToString("F2")</td>
                                <td>
                                    @if (item.PagoRealizado)
                                    {
                                        <span class="badge bg-success">Pagado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Pendiente</span>
                                    }
                                </td>
                                <td>@(item.NotaFinal?.ToString("F1") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No tiene materias inscritas.</p>
        }
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5>Materias Disponibles</h5>
    </div>
    <div class="card-body">
        @{
            var materiasDisponibles = ViewBag.MateriasDisponibles 
                as IEnumerable<SistemaGestionAcademica.Models.DTOs.MateriaDTO>;
        }
        @if (materiasDisponibles != null && materiasDisponibles.Any())
        {
            <div class="row">
                @foreach (var materia in materiasDisponibles)
                {
                    <div class="col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">@materia.Nombre</h5>
                                <p class="card-text text-muted">@materia.Descripcion</p>
                                <ul class="list-unstyled">
                                    <li><i class="bi bi-person"></i> <strong>Profesor:</strong> @materia.ProfesorNombre</li>
                                    <li><i class="bi bi-clock"></i> <strong>Horario:</strong> @materia.Horario</li>
                                    <li><i class="bi bi-door-open"></i> <strong>Aula:</strong> @materia.Aula</li>
                                    <li><i class="bi bi-people"></i> <strong>Cupos:</strong> @materia.CuposDisponibles</li>
                                    <li><i class="bi bi-cash"></i> <strong>Costo:</strong> Bs. @materia.Costo.ToString("F2")</li>
                                </ul>
                                <form asp-action="Inscribir" method="post">
                                    <input type="hidden" name="materiaId" value="@materia.Id" />
                                    <button type="submit" class="btn btn-primary btn-sm" 
                                            @(materia.CuposDisponibles <= 0 ? "disabled" : "")>
                                        <i class="bi bi-plus-lg"></i> Inscribirse
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted">No hay materias disponibles en este momento.</p>
        }
    </div>
</div>