@model SistemaGestionAcademica.Models.DTOs.HorarioCompletoDTO
@{
    ViewData["Title"] = "Mi Horario de Clases";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row mb-4">
    <div class="col-12">
        <h2><i class="bi bi-calendar-week"></i> @ViewData["Title"]</h2>
        <hr />
    </div>
</div>

@if (Model != null && Model.Materias != null && Model.Materias.Any())
{
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5><i class="bi bi-list-ul"></i> Mis Materias</h5>
        </div>
        <div class="card-body">
            <div class="row">
                @foreach (var materia in Model.Materias)
                {
                    <div class="col-md-6 mb-3">
                        <div class="card h-100 border-primary">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h5 class="card-title text-primary">@materia.MateriaNombre</h5>
                                    <span class="badge bg-primary">@materia.Dia</span>
                                </div>
                                <hr />
                                <ul class="list-unstyled">
                                    <li class="mb-2">
                                        <i class="bi bi-clock text-primary"></i>
                                        <strong>Horario:</strong> @materia.HoraInicio - @materia.HoraFin
                                    </li>
                                    <li class="mb-2">
                                        <i class="bi bi-person text-success"></i>
                                        <strong>Profesor:</strong> @materia.Profesor
                                    </li>
                                    <li class="mb-2">
                                        <i class="bi bi-door-open text-warning"></i>
                                        <strong>Aula:</strong> @materia.Aula
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-calendar-x" style="font-size: 5rem; color: #ccc;"></i>
        <h3 class="text-muted mt-3">No tienes materias inscritas</h3>
        <p class="text-muted">Inscribete en materias para ver tu horario de clases.</p>
        <a asp-action="Inscripciones" class="btn btn-primary btn-lg mt-3">
            <i class="bi bi-pencil-square"></i> Ver Materias Disponibles
        </a>
    </div>
}