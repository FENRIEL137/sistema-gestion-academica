@{
    ViewData["Title"] = "Buscar Estudiante";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row mb-4">
    <div class="col-12">
        <h2><i class="bi bi-search"></i> @ViewData["Title"]</h2>
        <p class="text-muted">Busque al estudiante por CI para registrar su pago</p>
        <hr />
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5><i class="bi bi-credit-card"></i> Ingrese CI del Estudiante</h5>
            </div>
            <div class="card-body">
                <form asp-action="BuscarEstudiantePago" method="post">
                    <div class="mb-3">
                        <label class="form-label">Cedula de Identidad</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-credit-card"></i></span>
                            <input name="ci" class="form-control form-control-lg"
                                   placeholder="Ej: 12345678" required autofocus />
                        </div>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-search"></i> Buscar Estudiante
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>