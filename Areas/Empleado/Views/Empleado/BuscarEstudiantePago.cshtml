@{
    ViewData["Title"] = "Buscar Estudiante";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row mb-4">
    <div class="col-12">
        <h2><i class="bi bi-search"></i> @ViewData["Title"]</h2>
        <p class="text-muted">Busque al estudiante por CI o nombre para registrar su pago</p>
        <hr />
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5><i class="bi bi-credit-card"></i> Buscar Estudiante</h5>
            </div>
            <div class="card-body">
                <form asp-action="BuscarEstudiantePago" method="post">
                    <div class="mb-3">
                        <label class="form-label">CI o Nombre del Estudiante</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input name="busqueda" class="form-control form-control-lg"
                                   placeholder="Ej: 12345678 o Juan Perez" required autofocus />
                        </div>
                        <small class="text-muted">Puede buscar por CI exacto o por nombre completo</small>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-search"></i> Buscar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>