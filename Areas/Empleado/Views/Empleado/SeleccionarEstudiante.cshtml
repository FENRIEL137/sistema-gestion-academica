@{
    ViewData["Title"] = "Seleccionar Estudiante";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var busqueda = ViewBag.Busqueda as string;
    var resultados = ViewBag.Resultados as List<SistemaGestionAcademica.Models.Entities.Estudiante>;
}

<div class="row mb-4">
    <div class="col-12">
        <h2><i class="bi bi-list-ul"></i> @ViewData["Title"]</h2>
        <p class="text-muted">Se encontraron varios estudiantes con: <strong>"@busqueda"</strong></p>
        <hr />
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (resultados != null && resultados.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>CI</th>
                            <th>Nombre Completo</th>
                            <th>Telefono</th>
                            <th>Accion</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var estudiante in resultados)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@estudiante.CI</span></td>
                                <td><strong>@estudiante.NombreCompleto</strong></td>
                                <td>@(estudiante.Telefono ?? "-")</td>
                                <td>
                                    <a asp-action="SeleccionarEstudiantePago" asp-route-id="@estudiante.Id"
                                       class="btn btn-primary btn-sm">
                                        <i class="bi bi-check-lg"></i> Seleccionar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No se encontraron resultados.</p>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="BuscarEstudiantePago" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Nueva busqueda
    </a>
</div>