@model IEnumerable<SistemaGestionAcademica.Models.Entities.Estudiante>
@{
    ViewData["Title"] = "Gestion de Estudiantes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people"></i> @ViewData["Title"]</h2>
    <a asp-action="CrearEstudiante" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nuevo Estudiante
    </a>
</div>

<div class="card">
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre Completo</th>
                            <th>CI</th>
                            <th>Telefono</th>
                            <th>Correo</th>
                            <th>Fecha Inscripcion</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var estudiante in Model)
                        {
                            <tr>
                                <td>@estudiante.NombreCompleto</td>
                                <td>@estudiante.CI</td>
                                <td>@(estudiante.Telefono ?? "-")</td>
                                <td>@(estudiante.Correo ?? "-")</td>
                                <td>@estudiante.FechaInscripcion.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (estudiante.Activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="DetallesEstudiante" asp-route-id="@estudiante.Id" 
                                           class="btn btn-outline-info" title="Ver detalles">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="EditarEstudiante" asp-route-id="@estudiante.Id" 
                                           class="btn btn-outline-primary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (estudiante.Activo)
                                        {
                                            <form asp-action="DarBajaEstudiante" asp-route-id="@estudiante.Id" 
                                                  method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-warning" 
                                                        title="Dar de baja"
                                                        onclick="return confirm('Esta seguro de dar de baja a este estudiante?')">
                                                    <i class="bi bi-person-x"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="ReactivarEstudiante" asp-route-id="@estudiante.Id" 
                                                  method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-success" 
                                                        title="Reactivar">
                                                    <i class="bi bi-person-check"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-people" style="font-size: 3rem; color: #ccc;"></i>
                <h4 class="text-muted mt-3">No hay estudiantes registrados</h4>
                <a asp-action="CrearEstudiante" class="btn btn-primary mt-2">
                    <i class="bi bi-plus-lg"></i> Registrar Primer Estudiante
                </a>
            </div>
        }
    </div>
</div>