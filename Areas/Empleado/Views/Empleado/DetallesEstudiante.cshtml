@model SistemaGestionAcademica.Models.Entities.Estudiante
@{
    ViewData["Title"] = "Detalles del Estudiante";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var inscripciones = ViewBag.Inscripciones as IEnumerable<SistemaGestionAcademica.Models.Entities.Inscripcion>;
    var historialPagos = ViewBag.HistorialPagos as IEnumerable<SistemaGestionAcademica.Models.Entities.Pago>;
    var deudaTotal = ViewBag.DeudaTotal ?? 0m;
}

<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Estudiantes">Estudiantes</a></li>
                <li class="breadcrumb-item active">@Model.NombreCompleto</li>
            </ol>
        </nav>
        <h2><i class="bi bi-person-vcard"></i> @ViewData["Title"]</h2>
        <hr />
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5><i class="bi bi-person"></i> Datos Personales</h5>
            </div>
            <div class="card-body">
                <div class="text-center mb-3">
                    <div class="avatar bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center" 
                         style="width: 80px; height: 80px; font-size: 2rem;">
                        @Model.NombreCompleto.Substring(0, 1).ToUpper()
                    </div>
                    <h4 class="mt-2">@Model.NombreCompleto</h4>
                    @if (Model.Activo)
                    {
                        <span class="badge bg-success fs-6">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6">Inactivo</span>
                    }
                </div>

                <hr />

                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        <span>CI:</span>
                        <strong>@Model.CI</strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Telefono:</span>
                        <strong>@(Model.Telefono ?? "No registrado")</strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Correo:</span>
                        <strong>@(Model.Correo ?? "No registrado")</strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Fecha Inscripcion:</span>
                        <strong>@Model.FechaInscripcion.ToString("dd/MM/yyyy")</strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Pago Inicial:</span>
                        <strong class="text-success">Bs. @Model.PagoInicial.ToString("F2")</strong>
                    </li>
                    @if (!Model.Activo && Model.FechaBaja.HasValue)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Fecha Baja:</span>
                            <strong class="text-danger">@Model.FechaBaja.Value.ToString("dd/MM/yyyy")</strong>
                        </li>
                    }
                </ul>
            </div>
            <div class="card-footer">
                <div class="d-grid gap-2">
                    <a asp-action="EditarEstudiante" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                        Editar Datos
                    </a>
                    @if (Model.Activo)
                    {
                        <form asp-action="DarBajaEstudiante" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn btn-warning btn-sm w-100" 
                                    onclick="return confirm('Esta seguro de dar de baja a este estudiante?')">
                                Dar de Baja
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="ReactivarEstudiante" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn btn-success btn-sm w-100">
                                Reactivar
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <h5>Materias Inscritas</h5>
            </div>
            <div class="card-body">
                @if (inscripciones != null && inscripciones.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>ID Inscripcion</th>
                                    <th>Materia</th>
                                    <th>Profesor</th>
                                    <th>Horario</th>
                                    <th>Aula</th>
                                    <th>Pago</th>
                                    <th>Nota</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inscripcion in inscripciones)
                                {
                                    <tr>
                                        <td>@inscripcion.Materia.Nombre</td>
                                        <td>@(inscripcion.Materia.Profesor?.NombreCompleto ?? "Sin asignar")</td>
                                        <td>@(inscripcion.Materia.Horario?.HorarioCompleto ?? "Sin horario")</td>
                                        <td>@(inscripcion.Materia.Aula?.Nombre ?? "Sin aula")</td>
                                        <td>
                                            @if (inscripcion.PagoRealizado)
                                            {
                                                <span class="badge bg-success">Pagado</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">Pendiente</span>
                                            }
                                        </td>
                                        <td>@(inscripcion.NotaFinal?.ToString("F1") ?? "-")</td>
                                        <td>@inscripcion.Estado</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No tiene materias inscritas.</p>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-success text-white">
                <h5>Historial de Pagos</h5>
            </div>
            <div class="card-body">
                @if (historialPagos != null && historialPagos.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Fecha</th>
                                    <th>Concepto</th>
                                    <th>Monto</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pago in historialPagos)
                                {
                                    <tr>
                                        <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                                        <td>@(pago.Concepto ?? pago.Tipo.ToString())</td>
                                        <td>Bs. @pago.Monto.ToString("F2")</td>
                                        <td>@pago.Estado</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No hay pagos registrados.</p>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-@(deudaTotal > 0 ? "danger" : "success") text-white">
                <h5>Resumen Financiero</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-md-6">
                        <h6>Deuda Total</h6>
                        <h3 class="@(deudaTotal > 0 ? "text-danger" : "text-success")">
                            Bs. @deudaTotal
                        </h3>
                    </div>
                    <div class="col-md-6">
                        <h6>Estado</h6>
                        @if (deudaTotal > 0)
                        {
                            <span class="badge bg-danger fs-6">Con Deuda</span>
                        }
                        else
                        {
                            <span class="badge bg-success fs-6">Al Dia</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Estudiantes" class="btn btn-secondary">
        Volver a Estudiantes
    </a>
</div>