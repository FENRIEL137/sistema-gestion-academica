@model IEnumerable<SistemaGestionAcademica.Models.Entities.Inscripcion>
@{
    ViewData["Title"] = "Registrar Pago";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var estudiante = ViewBag.Estudiante as SistemaGestionAcademica.Models.Entities.Estudiante;
}

<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Dashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="BuscarEstudiantePago">Buscar Estudiante</a></li>
                <li class="breadcrumb-item active">Registrar Pago</li>
            </ol>
        </nav>
        <h2><i class="bi bi-cash-stack"></i> @ViewData["Title"]</h2>
        <hr />
    </div>
</div>

@if (estudiante != null)
{
    <div class="card mb-4">
        <div class="card-header bg-info text-white">
            <h5><i class="bi bi-person-check"></i> Datos del Estudiante</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <strong>Nombre:</strong> @estudiante.NombreCompleto
                </div>
                <div class="col-md-4">
                    <strong>CI:</strong> @estudiante.CI
                </div>
                <div class="col-md-4">
                    <strong>Telefono:</strong> @(estudiante.Telefono ?? "No registrado")
                </div>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card">
            <div class="card-header bg-warning">
                <h5><i class="bi bi-exclamation-circle"></i> Materias Pendientes de Pago</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>ID Inscripcion</th>
                                <th>Materia</th>
                                <th>Costo</th>
                                <th>Fecha Inscripcion</th>
                                <th>Accion</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inscripcion in Model)
                            {
                                <tr>
                                    <td><span class="badge bg-dark">#@inscripcion.Id</span></td>
                                    <td>@inscripcion.Materia.Nombre</td>
                                    <td><strong>Bs. @inscripcion.Materia.Costo.ToString("F2")</strong></td>
                                    <td>@inscripcion.FechaInscripcion.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <button class="btn btn-success btn-sm"
                                                onclick="registrarPago(@inscripcion.Id, @inscripcion.Materia.Costo, @estudiante.Id)">
                                            <i class="bi bi-cash"></i> Pagar
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle"></i> El estudiante no tiene materias pendientes de pago.
        </div>
    }
}

<div class="mt-3">
    <a asp-action="BuscarEstudiantePago" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Buscar otro estudiante
    </a>
</div>

<!-- Modal de Pago -->
<div class="modal fade" id="pagoModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-cash"></i> Confirmar Pago</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ProcesarPago" method="post">
                <div class="modal-body">
                    <input type="hidden" name="inscripcionId" id="modalInscripcionId" />
                    <input type="hidden" name="estudianteId" id="modalEstudianteId" />

                    <div class="mb-3">
                        <label class="form-label">Monto a Pagar (Bs.)</label>
                        <input type="number" name="monto" id="modalMonto" class="form-control"
                               step="0.01" min="0" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Concepto</label>
                        <select name="concepto" class="form-select">
                            <option value="Pago de materia">Pago de Materia</option>
                            <option value="Pago con penalizacion">Pago con Penalizacion</option>
                            <option value="Pago parcial">Pago Parcial</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> Confirmar Pago
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function registrarPago(inscripcionId, monto, estudianteId) {
            document.getElementById('modalInscripcionId').value = inscripcionId;
            document.getElementById('modalMonto').value = monto;
            document.getElementById('modalEstudianteId').value = estudianteId;
            var modal = new bootstrap.Modal(document.getElementById('pagoModal'));
            modal.show();
        }
    </script>
}