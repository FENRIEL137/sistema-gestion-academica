@model IEnumerable<SistemaGestionAcademica.Models.DTOs.ActividadDTO>
@{
    ViewData["Title"] = "Gestion de Actividades";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-list-check"></i> @ViewData["Title"]</h2>
    <a asp-action="CrearActividad" asp-route-materiaId="@ViewBag.MateriaId" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nueva Actividad
    </a>
</div>

<div class="card">
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Fecha</th>
                            <th>Valor %</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var actividad in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@actividad.Nombre</strong>
                                    @if (!string.IsNullOrEmpty(actividad.Descripcion))
                                    {
                                        <br /><small class="text-muted">@actividad.Descripcion</small>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-info">@actividad.Tipo</span>
                                </td>
                                <td>@actividad.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@actividad.ValorPorcentual%</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditarActividad" asp-route-id="@actividad.Id" 
                                           class="btn btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="EliminarActividad" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@actividad.Id" />
                                            <input type="hidden" name="materiaId" value="@ViewBag.MateriaId" />
                                            <button type="submit" class="btn btn-outline-danger" 
                                                    onclick="return confirm('Eliminar esta actividad?')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-secondary">
                            <td colspan="3" class="text-end"><strong>Total Porcentaje:</strong></td>
                            <td><strong>@Model.Sum(a => a.ValorPorcentual)%</strong></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-4">
                <i class="bi bi-list-check" style="font-size: 3rem; color: #ccc;"></i>
                <h5 class="text-muted mt-2">No hay actividades registradas</h5>
                <a asp-action="CrearActividad" asp-route-materiaId="@ViewBag.MateriaId" 
                   class="btn btn-primary mt-2">
                    <i class="bi bi-plus-lg"></i> Crear Primera Actividad
                </a>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Materias" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Volver a Materias
    </a>
</div>