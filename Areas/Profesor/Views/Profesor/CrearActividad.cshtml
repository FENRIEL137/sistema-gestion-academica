@model SistemaGestionAcademica.Models.ViewModels.ActividadViewModel
@using SistemaGestionAcademica.Models.Entities
@{
    ViewData["Title"] = "Nueva Actividad";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4><i class="bi bi-plus-circle"></i> @ViewData["Title"]</h4>
            </div>
            <div class="card-body">
                <form asp-action="CrearActividad" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="MateriaId" />

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label">Nombre de la Actividad</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Nombre de la actividad" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label">Descripcion</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3" 
                                  placeholder="Descripcion opcional"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Fecha" class="form-label">Fecha</label>
                            <input asp-for="Fecha" class="form-control" type="date" 
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="Fecha" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Tipo" class="form-label">Tipo de Actividad</label>
                            <select asp-for="Tipo" class="form-select" 
                                    asp-items="Html.GetEnumSelectList<TipoActividad>()">
                                <option value="">Seleccione tipo...</option>
                            </select>
                            <span asp-validation-for="Tipo" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="ValorPorcentual" class="form-label">Valor Porcentual</label>
                            <div class="input-group">
                                <input asp-for="ValorPorcentual" class="form-control" 
                                       type="number" step="0.01" min="0" max="100" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="ValorPorcentual" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Actividades" asp-route-materiaId="@Model.MateriaId" 
                           class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Crear Actividad
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {

}