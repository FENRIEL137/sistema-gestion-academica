@model SistemaGestionAcademica.Models.Entities.Materia
@{
    ViewData["Title"] = "Nueva Materia";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4><i class="bi bi-plus-circle"></i> @ViewData["Title"]</h4>
            </div>
            <div class="card-body">
                <form asp-action="CrearMateria" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label">Nombre de la Materia</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Nombre de la materia" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label">Descripcion</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3" 
                                  placeholder="Descripcion de la materia (opcional)"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Costo" class="form-label">Costo (Bs.)</label>
                        <div class="input-group">
                            <span class="input-group-text">Bs.</span>
                            <input asp-for="Costo" class="form-control" type="number" step="0.01" min="0" 
                                   placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Costo" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="ProfesorId" class="form-label">Profesor</label>
                            <select asp-for="ProfesorId" class="form-select" asp-items="ViewBag.Profesores">
                                <option value="">-- Seleccionar --</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="AulaId" class="form-label">Aula</label>
                            <select asp-for="AulaId" class="form-select" asp-items="ViewBag.Aulas">
                                <option value="">-- Seleccionar --</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="HorarioId" class="form-label">Horario</label>
                            <select asp-for="HorarioId" class="form-select" asp-items="ViewBag.Horarios">
                                <option value="">-- Seleccionar --</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Materias" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Crear Materia
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {

}