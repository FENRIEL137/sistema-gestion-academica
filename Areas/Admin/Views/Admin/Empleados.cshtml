@model IEnumerable<SistemaGestionAcademica.Models.Entities.Empleado>
@{
    ViewData["Title"] = "Gestion de Empleados";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-badge"></i> @ViewData["Title"]</h2>
    <a asp-action="CrearEmpleado" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nuevo Empleado
    </a>
</div>

<div class="card">
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre Completo</th>
                            <th>CI</th>
                            <th>Cargo</th>
                            <th>Telefono</th>
                            <th>Correo</th>
                            <th>Fecha Contratacion</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var empleado in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@empleado.NombreCompleto</strong>
                                </td>
                                <td>@empleado.CI</td>
                                <td>
                                    <span class="badge bg-secondary">@empleado.Cargo</span>
                                </td>
                                <td>@(empleado.Telefono ?? "-")</td>
                                <td>@(empleado.Correo ?? "-")</td>
                                <td>@empleado.FechaContratacion.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (empleado.Activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditarEmpleado" asp-route-id="@empleado.Id" 
                                           class="btn btn-outline-primary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (empleado.Activo)
                                        {
                                            <form asp-action="EliminarEmpleado" asp-route-id="@empleado.Id" 
                                                  method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger" 
                                                        title="Dar de baja"
                                                        onclick="return confirm('Esta seguro de dar de baja a este empleado?')">
                                                    <i class="bi bi-person-x"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-people" style="font-size: 3rem; color: #ccc;"></i>
                <h4 class="text-muted mt-3">No hay empleados registrados</h4>
                <a asp-action="CrearEmpleado" class="btn btn-primary mt-2">
                    <i class="bi bi-plus-lg"></i> Crear Primer Empleado
                </a>
            </div>
        }
    </div>
    @if (Model != null && Model.Any())
    {
        <div class="card-footer text-muted">
            <small>Total: @Model.Count() empleados</small>
        </div>
    }
</div>