@model SistemaGestionAcademica.Models.Entities.Aula
@{
    ViewData["Title"] = "Nueva Aula";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4><i class="bi bi-plus-circle"></i> @ViewData["Title"]</h4>
            </div>
            <div class="card-body">
                <form asp-action="CrearAula" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Codigo" class="form-label">Codigo</label>
                            <input asp-for="Codigo" class="form-control" placeholder="Ej: A101, LAB1" />
                            <span asp-validation-for="Codigo" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombre" class="form-label">Nombre</label>
                            <input asp-for="Nombre" class="form-control" placeholder="Nombre del aula" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Capacidad" class="form-label">Capacidad</label>
                            <input asp-for="Capacidad" class="form-control" type="number" 
                                   min="1" max="200" placeholder="30" />
                            <span asp-validation-for="Capacidad" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Ubicacion" class="form-label">Ubicacion</label>
                            <input asp-for="Ubicacion" class="form-control" 
                                   placeholder="Ej: Primer Piso, Edificio A" />
                            <span asp-validation-for="Ubicacion" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="EsLaboratorio" class="form-check-input" type="checkbox" />
                            <label asp-for="EsLaboratorio" class="form-check-label">Es Laboratorio</label>
                        </div>
                        <small class="text-muted">
                            Marque esta opcion si el aula es un laboratorio (computacion, ciencias, etc.)
                        </small>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Aulas" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Crear Aula
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}