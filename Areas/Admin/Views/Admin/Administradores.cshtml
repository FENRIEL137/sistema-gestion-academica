@model IEnumerable<SistemaGestionAcademica.Models.Entities.ApplicationUser>
@{
    ViewData["Title"] = "Administradores";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-shield-lock"></i> @ViewData["Title"]</h2>
    <a asp-action="CrearAdministrador" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nuevo Administrador
    </a>
</div>

<div class="card">
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Fecha Registro</th>
                            <th>Ultimo Acceso</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var admin in Model)
                        {
                            <tr>
                                <td><strong>@admin.NombreCompleto</strong></td>
                                <td>@admin.Email</td>
                                <td>@admin.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                <td>@(admin.UltimoAcceso?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca")</td>
                                <td>
                                    @if (admin.Activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditarAdministrador" asp-route-id="@admin.Id"
                                           class="btn btn-outline-primary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="EliminarAdministrador" asp-route-id="@admin.Id"
                                              method="post" class="d-inline">
                                            <button type="submit" class="btn btn-outline-danger"
                                                    title="Desactivar"
                                                    onclick="return confirm('Esta seguro de desactivar este administrador?')">
                                                <i class="bi bi-person-x"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-4">
                <i class="bi bi-shield-lock" style="font-size: 3rem; color: #ccc;"></i>
                <h5 class="text-muted mt-2">No hay administradores registrados</h5>
            </div>
        }
    </div>
</div>