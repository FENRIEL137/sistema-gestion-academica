@model SistemaGestionAcademica.Models.Entities.ConfiguracionInstitucional
@{
    ViewData["Title"] = "Configuracion Institucional";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row mb-4">
    <div class="col-12">
        <h2><i class="bi bi-gear"></i> @ViewData["Title"]</h2>
        <hr />
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5><i class="bi bi-sliders"></i> Parametros Generales</h5>
            </div>
            <div class="card-body">
                <form asp-action="Configuracion" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Activo" />

                    <div class="mb-3">
                        <label asp-for="NombreInstitucion" class="form-label">Nombre de la Institucion</label>
                        <input asp-for="NombreInstitucion" class="form-control" />
                        <span asp-validation-for="NombreInstitucion" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PeriodoActual" class="form-label">Periodo Actual</label>
                        <input asp-for="PeriodoActual" class="form-control" placeholder="Ej: 2026-I" />
                        <span asp-validation-for="PeriodoActual" class="text-danger"></span>
                    </div>

                    <hr />
                    <h5><i class="bi bi-cash"></i> Configuracion de Pagos</h5>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PagoInicialInscripcion" class="form-label">Pago Inicial de Inscripcion</label>
                            <div class="input-group">
                                <span class="input-group-text">Bs.</span>
                                <input asp-for="PagoInicialInscripcion" class="form-control" 
                                       type="number" step="0.01" min="0" />
                            </div>
                            <small class="text-muted">Monto que deben pagar los estudiantes al inscribirse</small>
                            <span asp-validation-for="PagoInicialInscripcion" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CostoBaseMateria" class="form-label">Costo Base por Materia</label>
                            <div class="input-group">
                                <span class="input-group-text">Bs.</span>
                                <input asp-for="CostoBaseMateria" class="form-control" 
                                       type="number" step="0.01" min="0" />
                            </div>
                            <small class="text-muted">Costo base por materia (puede variar por materia)</small>
                            <span asp-validation-for="CostoBaseMateria" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PorcentajePenalizacionMora" class="form-label">Porcentaje de Penalizacion por Mora</label>
                        <div class="input-group">
                            <input asp-for="PorcentajePenalizacionMora" class="form-control" 
                                   type="number" step="0.01" min="0" max="100" />
                            <span class="input-group-text">%</span>
                        </div>
                        <small class="text-muted">Porcentaje adicional por pago fuera de fecha</small>
                        <span asp-validation-for="PorcentajePenalizacionMora" class="text-danger"></span>
                    </div>

                    <hr />
                    <h5><i class="bi bi-calendar"></i> Periodo de Pagos</h5>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DiaInicioPagos" class="form-label">Dia de Inicio de Pagos</label>
                            <select asp-for="DiaInicioPagos" class="form-select">
                                @for (int i = 1; i <= 30; i++)
                                {
                                    <option value="@i">@i</option>
                                }
                            </select>
                            <small class="text-muted">Dia del mes en que inicia el periodo de pagos</small>
                            <span asp-validation-for="DiaInicioPagos" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DiaFinPagos" class="form-label">Dia de Fin de Pagos</label>
                            <select asp-for="DiaFinPagos" class="form-select">
                                @for (int i = 1; i <= 30; i++)
                                {
                                    <option value="@i">@i</option>
                                }
                            </select>
                            <small class="text-muted">Dia del mes en que finaliza el periodo de pagos</small>
                            <span asp-validation-for="DiaFinPagos" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Dashboard" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Volver
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Guardar Configuracion
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <h5><i class="bi bi-info-circle"></i> Informacion</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled">
                    <li class="mb-3">
                        <strong>Ultima Actualizacion:</strong><br />
                        <small class="text-muted">@Model.FechaUltimaActualizacion.ToString("dd/MM/yyyy HH:mm")</small>
                    </li>
                    <li class="mb-3">
                        <strong>Periodo Actual:</strong><br />
                        <span class="badge bg-primary">@Model.PeriodoActual</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle"></i>
                    <small>Los cambios en la configuracion afectaran a todos los procesos del sistema.</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}