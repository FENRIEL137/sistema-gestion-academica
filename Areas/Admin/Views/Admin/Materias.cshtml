@model IEnumerable<SistemaGestionAcademica.Models.Entities.Materia>
@{
    ViewData["Title"] = "Gestion de Materias";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-book"></i> @ViewData["Title"]</h2>
    <a asp-action="CrearMateria" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nueva Materia
    </a>
</div>

<div class="card">
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Descripcion</th>
                            <th>Profesor</th>
                            <th>Aula</th>
                            <th>Horario</th>
                            <th>Costo</th>
                            <th>Inscritos</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var materia in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@materia.Nombre</strong>
                                </td>
                                <td>
                                    <small class="text-muted">
                                        @if (!string.IsNullOrEmpty(materia.Descripcion))
                                        {
                                            if (materia.Descripcion.Length > 50)
                                            {
                                                @(materia.Descripcion.Substring(0, 50) + "...")
                                            }
                                            else
                                            {
                                                @materia.Descripcion
                                            }
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </small>
                                </td>
                                <td>@(materia.Profesor?.NombreCompleto ?? "Sin asignar")</td>
                                <td>@(materia.Aula?.Nombre ?? "Sin asignar")</td>
                                <td>@(materia.Horario?.HorarioCompleto ?? "Sin asignar")</td>
                                <td>Bs. @materia.Costo.ToString("F2")</td>
                                <td>
                                    <span class="badge bg-info">
                                        @(materia.Inscripciones?.Count ?? 0)
                                    </span>
                                </td>
                                <td>
                                    @if (materia.Activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditarMateria" asp-route-id="@materia.Id" 
                                           class="btn btn-outline-primary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-book" style="font-size: 3rem; color: #ccc;"></i>
                <h4 class="text-muted mt-3">No hay materias registradas</h4>
                <a asp-action="CrearMateria" class="btn btn-primary mt-2">
                    <i class="bi bi-plus-lg"></i> Crear Primera Materia
                </a>
            </div>
        }
    </div>
    @if (Model != null && Model.Any())
    {
        <div class="card-footer text-muted">
            <small>
                Total: @Model.Count() materias | 
                Activas: @Model.Count(m => m.Activo) | 
                Inactivas: @Model.Count(m => !m.Activo)
            </small>
        </div>
    }
</div>