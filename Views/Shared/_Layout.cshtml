@{
    var dashboardUrl = Url.Action("Index", "Home");

    if (User.IsInRole("Administrador"))
        dashboardUrl = Url.Action("Dashboard", "Admin", new { area = "Admin" });
    else if (User.IsInRole("Empleado"))
        dashboardUrl = Url.Action("Dashboard", "Empleado", new { area = "Empleado" });
    else if (User.IsInRole("Profesor"))
        dashboardUrl = Url.Action("Dashboard", "Profesor", new { area = "Profesor" });
    else if (User.IsInRole("Estudiante"))
        dashboardUrl = Url.Action("Dashboard", "Estudiante", new { area = "Estudiante" });
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0d6efd">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="SIGA">
    <link rel="apple-touch-icon" href="/images/icon-192.png">
    <title>@ViewData["Title"] - SIGA</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" href="@dashboardUrl">
                    <i class="bi bi-mortarboard-fill"></i> SIGA
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <ul class="navbar-nav me-auto">
                            @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-people-fill"></i> Personas</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Admin" asp-action="Profesores">Profesores</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Admin" asp-action="Empleados">Empleados</a></li>
                                    </ul>
                                </li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Admin" asp-action="Administradores">Administradores</a></li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-gear"></i> Gestion</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Admin" asp-action="Materias">Materias</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Admin" asp-action="Aulas">Aulas</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Admin" asp-action="Configuracion">Configuracion</a></li>
                                    </ul>
                                </li>
                            }
                            @if (User.IsInRole("Profesor"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-area="Profesor" asp-controller="Profesor" asp-action="Materias"><i class="bi bi-book"></i> Mis Materias</a></li>
                            }
                            @if (User.IsInRole("Estudiante"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-area="Estudiante" asp-controller="Estudiante" asp-action="Inscripciones"><i class="bi bi-pencil-square"></i> Inscripciones</a></li>
                                <li class="nav-item"><a class="nav-link" asp-area="Estudiante" asp-controller="Estudiante" asp-action="Pagos"><i class="bi bi-cash-coin"></i> Pagos</a></li>
                                <li class="nav-item"><a class="nav-link" asp-area="Estudiante" asp-controller="Estudiante" asp-action="Notas"><i class="bi bi-bar-chart"></i> Notas</a></li>
                            }
                            @if (User.IsInRole("Empleado"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-area="Empleado" asp-controller="Empleado" asp-action="Estudiantes"><i class="bi bi-people"></i> Estudiantes</a></li>
                                <li class="nav-item"><a class="nav-link" asp-area="Empleado" asp-controller="Empleado" asp-action="Pagos"><i class="bi bi-cash-stack"></i> Pagos</a></li>
                                <li class="nav-item"><a class="nav-link" asp-area="Empleado" asp-controller="Empleado" asp-action="Deudas"><i class="bi bi-exclamation-triangle"></i> Deudas</a></li>
                            }
                        </ul>
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i> @User.Identity?.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"><i class="bi bi-key"></i> Cambiar Contrasena</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="/Account/Logout"><i class="bi bi-box-arrow-right"></i> Cerrar Sesion</a></li>
                                </ul>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right"></i> Iniciar Sesion</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus"></i> Registrarse</a></li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container mt-4 mb-5">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">@TempData["ErrorMessage"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        @RenderBody()
    </main>

    <footer class="footer mt-auto py-3 bg-light border-top">
        <div class="container text-center">
            <span class="text-muted">&copy; @DateTime.Now.Year - SIGA</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js');
        }
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>